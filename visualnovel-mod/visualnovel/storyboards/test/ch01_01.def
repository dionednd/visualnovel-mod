layer0.scale = 1.5
layer0.speaker = "dionednd"

; Choices
choice0.text = "Yes."
choice0.value = 1
; we return " if this choice is chosen.
choice0.jump = 4
; we jump to scene 4 if this choice is chosen
choice1.text = "No."
choice1.value = 0
; we return 0 if this choice is chosen.
choice1.jump = 14
; we jump to scene 5 if this choice is chosen

