; Visual Novel System by dionednd
; Motif Defaults

;------------------------------------------------------------------------
[Info]
localcoord = 1280,720

;------------------------------------------------------------------------
[VisualNovel Info]

;Speaker Text

player.name = "$playername$"

speaker.offset = 23,510
speaker.font = 7,0,1,0,255,255
speaker.scale = 1.333333333333333, 1.333333333333333

; Input BG
input.bg.spr = 700,0
input.bg.scale = 0.25, 0.2
input.bg.offset = 481, 150
input.bg.facing = 1

; Input Text
input.text.font = 7,0,0,255,255,255
input.text.scale = 1.0, 1.0
input.text.offset = 640, 180
input.text.xshear = 0
input.text.angle = 0
input.text.projection = "orthographic"
input.text.focallength = 2048
input.text.window = 0, 0, 1280, 720
input.text.cursor = "|"
input.text.cursorblink = 30

; Choice BG
choice.inactive.bg.spr = 700,0
choice.inactive.bg.scale = 0.25, 0.2
choice.inactive.bg.offset = 481, 150
choice.inactive.bg.facing = 1

choice.active.bg.spr = 700,0
choice.active.bg.scale = 0.25, 0.2
choice.active.bg.offset = 481, 150
choice.active.bg.facing = 1

; Choice Text
choice.inactive.text.font = 7,0,0,128,128,128
choice.inactive.text.scale = 1.0, 1.0
choice.inactive.text.offset = 640, 180
choice.inactive.text.xshear = 0
choice.inactive.text.angle = 0
choice.inactive.text.projection = "orthographic"
choice.inactive.text.focallength = 2048
choice.inactive.text.window = 0, 0, 1280, 720

choice.active.text.font = 7,0,0
choice.active.text.scale = 1.0, 1.0
choice.active.text.offset = 640, 180
choice.active.text.xshear = 0
choice.active.text.angle = 0
choice.active.text.projection = "orthographic"
choice.active.text.focallength = 2048
choice.active.text.window = 0, 0, 1280, 720

choice.lockedtext = "Locked"

choice.spacing = 60

; key binds
key.action = a, b, c, x, y, z, s
key.quicksave = "F9"
key.quickload = "F10"
key.pause = m
key.next = D, L
key.previous = U, R

key.up = U, B
key.down = D, F
scrolldelay = 4

move.snd = 100, 0
cancel.snd = 100, 2
done.snd = 100, 1
locked.snd = 100, 0

